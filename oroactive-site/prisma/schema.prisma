generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FOUNDER
  ADMIN
  MANAGER
  OPERATOR
  STUDENT
}

enum CourseLevel {
  BASE
  INTERMEDIO
  AVANZATO
  MASTER
}

enum ProgressStatus {
  NON_INIZIATO
  IN_CORSO
  COMPLETATO
  IN_ATTESA_ESAME
  CERTIFICATO
}

model User {
  id             String          @id @default(cuid())
  name           String
  surname        String
  email          String          @unique
  passwordHash   String
  role           UserRole        @default(STUDENT)
  storeId        String?
  store          Store?          @relation(fields: [storeId], references: [id])
  progress       CourseProgress[]
  certificates   Certificate[]
  badges         Badge[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Store {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  code        String   @unique
  address     String
  city        String
  province    String
  phone       String?
  email       String?
  latitude    Float?
  longitude   Float?
  active      Boolean  @default(true)
  users       User[]
  leads       Lead[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quote {
  id        String   @id @default(cuid())
  metal     String
  priceKg   Decimal  @db.Decimal(14, 2)
  currency  String   @default("EUR")
  source    String   @default("BullionVault")
  createdAt DateTime @default(now())
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  message   String?
  metal     String?
  grams     Decimal? @db.Decimal(12, 3)
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())
}

model Faculty {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  courses     Course[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Course {
  id                 String           @id @default(cuid())
  title              String
  slug               String           @unique
  description        String
  facultyId          String
  faculty            Faculty          @relation(fields: [facultyId], references: [id])
  category           String
  level              CourseLevel      @default(BASE)
  durationMinutes    Int              @default(0)
  teacher            String?
  thumbnailUrl       String?
  active             Boolean          @default(true)
  finalCertification Boolean          @default(true)
  modules            Module[]
  progress           CourseProgress[]
  certificates        Certificate[]
  badges             Badge[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Module {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
}

model Lesson {
  id          String     @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  order       Int        @default(0)
  moduleId    String
  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  materials   Material[]
}

model Material {
  id        String   @id @default(cuid())
  title     String
  type      String
  fileUrl   String?
  linkUrl   String?
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model CourseProgress {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  percent     Int            @default(0)
  status      ProgressStatus @default(NON_INIZIATO)
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime       @updatedAt
  @@unique([userId, courseId])
}

model Certificate {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  pdfUrl    String?
  valid     Boolean  @default(true)
  issuedAt  DateTime @default(now())
}

model Badge {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status    String   @default("valido")
  issuedAt  DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  category    String
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AiKnowledge {
  id        String   @id @default(cuid())
  title     String
  content   String
  source    String
  category  String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}
